# ESP-IDF build artefacts (regenerated by `idf.py build`)
/build/
/sdkconfig
/sdkconfig.old
/.cache/

# managed_components are downloaded by `idf.py reconfigure` from
# the IDF component manager. dependencies.lock pins their versions.
/managed_components/

# Project-local SPIFFS staging dir (we use a raw flash partition for
# the WAD instead, so this isn't actually used at runtime).
/spiffs/

# The DOOM shareware WAD is copyrighted by id Software. Don't ship it.
# Get it legally and run tools/flash_wad.sh to put it in flash.
/DOOM1.WAD
/DOOM.WAD
/DOOM_TRIM*.WAD
*.wad
*.WAD

# Python cache from tools/wad_audit.py / trim_wad.py
/tools/__pycache__/

# Bake output. Regenerated from the WAD by tools/bake_textures.py.
# Committed because it lets people clone-and-build without the WAD.
# (Uncomment the next line if you want a fresh bake every clone.)
# /main/baked_textures.c

# editor / OS junk
.DS_Store
*.swp
*.swo
.vscode/
.idea/
